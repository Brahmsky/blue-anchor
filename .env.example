# Copy this file to .env for local development.
# Do not commit real secrets.

# =========================
# Datasource selection
# =========================
# Preferred: select datasource by id or explicit root.
DATASOURCE_ID=demo_ship_docs
# DATASOURCE_ROOT=./examples/demo_datasource

# =========================
# Graph storage
# =========================
GRAPH_STORAGE=Neo4JStorage
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# =========================
# Query LLM / default LLM
# =========================
# Typical local OpenAI-compatible setup (LM Studio / local gateway).
LLM_BINDING=openai
LLM_BINDING_HOST=http://127.0.0.1:1234/v1
LLM_BINDING_API_KEY=EMPTY
LLM_MODEL=qwen3.5-2b

# Query path can be overridden independently.
QUERY_LLM_BINDING=openai
QUERY_LLM_BINDING_HOST=http://127.0.0.1:1234/v1
QUERY_LLM_BINDING_API_KEY=EMPTY
QUERY_LLM_MODEL=qwen3.5-2b

# =========================
# Embedding model
# =========================
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=http://127.0.0.1:1234/v1
EMBEDDING_BINDING_API_KEY=EMPTY
EMBEDDING_MODEL=text-embedding-qwen3-embedding-4b

# =========================
# Retrieval defaults
# =========================
TOP_K=50
COSINE_THRESHOLD=0.4
MAX_TOKENS=32768
MAX_TOKEN_FOR_TEXT_UNIT=8000
FAULTCASE_CHUNK_RECALL_TOP_K=15
FAULTCASE_CHUNK_LEXICAL_TOP_K=4
FAULTCASE_CHUNK_LEXICAL_SCAN_LIMIT=120

# =========================
# Local flash_rerank
# =========================
# Only used when flash_rerank is importable locally.
FAULTCASE_RERANK_ENABLED=false
FAULTCASE_RERANK_MODEL=BAAI/bge-reranker-base
FAULTCASE_RERANK_TIMEOUT_MS=20000
FAULTCASE_RERANK_MAX_CANDIDATES=6
FAULTCASE_RERANK_DEVICE=cpu
FAULTCASE_RERANK_PRECISION=fp32

# =========================
# Benchmark judge
# =========================
# Required only for cloud benchmark judging.
DEEPSEEK_API_KEY=
BENCHMARK_JUDGE_MODEL=deepseek-chat
BENCHMARK_JUDGE_BASE_URL=https://api.deepseek.com/v1
BENCHMARK_JUDGE_TIMEOUT_SECONDS=90

# Optional benchmark tuning.
BENCHMARK_TOP_K=8
BENCHMARK_MAX_TOKEN_FOR_TEXT_UNIT=8000
BENCHMARK_MAX_TOKEN_FOR_NODE_CONTEXT=300
BENCHMARK_RESPONSE_TYPE=Bullet List

# Optional local benchmark judge mode.
# BENCHMARK_LOCAL_JUDGE_URL=http://127.0.0.1:11434/v1
# BENCHMARK_LOCAL_JUDGE_MODEL=qwen3.5-2b
